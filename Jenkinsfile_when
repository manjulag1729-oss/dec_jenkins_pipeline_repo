pipeline {
    agent any

    stages {

        stage('STAGE1_a') {
            steps {
                echo "Executing Stage 1A"
            }
        }

        stage('STAGE1_b') {
            steps {
                echo "Checking out code from GitHub"

                checkout scmGit(
                    branches: [[name: '*/main']],
                    extensions: [],
                    userRemoteConfigs: [[
                        credentialsId: 'hp-git',
                        url: 'https://github.com/manjulag1729-oss/dec_jenkins_pipeline_repo.git'
                    ]]
                )

                echo "Checkout completed"
            }
        }

        stage('PARALLEL TESTING') {
            parallel {

                stage('MACOS TESTING') {
                    steps {
                        echo "Running tests on MacOS"
                    }
                }

                stage('WINDOWS TESTING') {
                    steps {
                        echo "Running tests on Windows"
                    }
                }

            }
        }

        stage('End') {
            steps {
                echo "Pipeline execution completed"
            }
        }

    }
}